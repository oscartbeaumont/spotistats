{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spotistats",
  "main": "@solidjs/start/server/entry",
  "compatibility_date": "2026-04-24",
  "compatibility_flags": ["nodejs_compat"],
  "route": {
    "pattern": "spotistats.otbeaumont.me",
    "custom_domain": true,
  },
  "observability": {
    "enabled": true,
  },
  "vars": {
    "SPOTIFY_CLIENT_ID": "1107a25b98c041bb90c9063553e5f1a8",
  },
  "secrets": {
    "required": ["SPOTIFY_CLIENT_SECRET"],
  },
}
